   "source": [
    "data_one_year = num_heatidx_histhours.sel(time=\"1985\")\n",
    "\n",
    "# visualize\n",
    "data_one_year.hvplot.line(x=\"time\", by=\"sim\").opts(\n",
    "    title=\"scenario: Historical Climate\"\n",
    ")  # a specific year\n",
    "# num_heatidx_histhours.hvplot.line(x='time', by='sim').opts(title=\"scenario: Historical Climate\") # all years"
   ]
